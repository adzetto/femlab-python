/empty 12 string def

% Other initializations.
/datewidth date stringwidth pop def
/filenameroom
	 pagewidth
	 filenamefontsize 4 mul datewidth add (Page  999) stringwidth pop add
      sub
   def


% Function startdoc: initializes printer and global variables.
/startdoc
    { /sheetside 0 def                  % sheet side that contains current page
      /sheet 1 def                      % sheet number
   } bind def

% Function newfile: init file name and reset page number for each new file.
/newfile
    { cleanup
      /filename xdef
      /filenamewidth filename stringwidth pop def
      /filenamefont
	 filenamewidth filenameroom gt
	 {
	       filenamefontname
	       filenamefontsize filenameroom mul filenamewidth div
	    getfont
	 }
	 {  stdfilenamefont }
	 ifelse
	 def
      /pagenum 1 def
    } bind def

% Function printpage: Print a physical page.
/printpage
    { /sheetside 0 def
      twinpage
      {  noborder not
	    { sheetnumber }
	 if
      }
      {  noheader noborder not and
	    { sheetnumber }
	 if
      }
      ifelse
      showpage
%      pagesave restore
      /sheet sheet 1 add def
    } bind def

% Function cleanup: terminates printing, flushing last page if necessary.
/cleanup
    { twinpage sheetside 1 eq and
	 { printpage }
      if
    } bind def

%
% Function startpage: prints page header and page border and initializes
% printing of the file lines.
/startpage
    { sheetside 0 eq
	{ % /pagesave save def
	  landscape
	    { sheetwidth 0 inch translate       % new coordinates system origin
	      90 rotate                         % landscape format
	    } if
	} if
      noborder not { printborder } if
      noheader not { printheader } if
	 upperx sheetside get  bodymargin  add
	    uppery
	    bodymargin bodyfontsize add  noheader {0} {headersize} ifelse  add
	 sub
      moveto
      bodyfont setfont
    } bind def

% Function printheader: prints page header.
/printheader
    { upperx sheetside get  uppery headersize sub 1 add  moveto
      datefont setfont
      gsave
	datefontsize headermargin rmoveto
	date show                                       % date/hour
      grestore
      gsave
	pagenum pnum cvs pop
	   pagewidth (Page  999) stringwidth pop sub
	   headermargin
	rmoveto
	makebook not
	{ (Page ) show pnum show                        % page number
	}
	{ (Page ) show abspnum show                     % page number
	}
	ifelse
      grestore
      empty pnum copy pop
      gsave
	filenamefont setfont
	      filenameroom filename stringwidth pop sub 2 div datewidth add
	      bodymargin 2 mul
	   add
	   headermargin
	rmoveto
	filename show                                           % file name
      grestore
    } bind def

% Function printborder: prints border page.
/printborder
    { upperx sheetside get uppery moveto
      gsave                                     % print the four sides
	pagewidth 0 rlineto                     % of the square
	0 pageheight neg rlineto
	pagewidth neg 0 rlineto
	closepath 
        stroke
      grestore
      gsave       
	pagewidth 0 rlineto                   
	0 headersize neg rlineto
	pagewidth neg 0 rlineto
	closepath 
        0.9 setgray
        fill
      grestore
      gsave       
	pagewidth 0 rlineto                   
	0 headersize neg rlineto
	pagewidth neg 0 rlineto
	closepath 
        stroke
      grestore
      noheader not
	 { 0 headersize neg rmoveto pagewidth 0 rlineto stroke }
      if
    } bind def

%
% Function endpage: adds a sheet number to the page (footnote) and prints
% the formatted page (physical impression). Activated at the end of each
% source page (lines reached or FF character).
/endpage
   { /pagenum pagenum 1 add def
     twinpage  sheetside 0 eq  and
	{ /sheetside 1 def }
	{ printpage }
     ifelse
   } bind def

% Function sheetnumber: prints the sheet number.
/sheetnumber
    { makebook not
      { sheetnumberx sheetnumbery moveto
	datefont setfont
	sheet pnum cvs
	   dup stringwidth pop (0) stringwidth pop sub neg 0 rmoveto show
	empty pnum copy pop
      }
      { sheetheight 2.02 div leftmargin 2 div moveto
	(|) show
	sheetheight 2.02 div sheetwidth leftmargin 2 div sub moveto
	(|) show
      }
      ifelse
    } bind def

% Function s: print a source line
/s  { gsave
	show
      grestore
      0 bodyfontsize neg rmoveto
    } bind def
/ml { currentpoint
    } bind def
/nl { moveto
      0 bodyfontsize neg rmoveto
    } bind def

%%EndProlog

/docsave save def
startdoc
(elastic.m) newfile
/sheet 1 def
%%Page: 1 1
startpage
ml
( %.........................................) s
nl
ml
( % File:elastic.m ) s
nl
ml
( %) s
nl
ml
( % Driver for linear analysis of elastic ) s
nl
ml
( % problem with Q4E elements. ) s
nl
ml
( %) s
nl
ml
( % Required input:) s
nl
ml
( %  T:   Topology) s
nl
ml
( %  X:   Node coordinates) s
nl
ml
( %  G:   Material properties) s
nl
ml
( %  C:   Prescribed displacements) s
nl
ml
( %  P:   Prescribed nodal loads) s
nl
ml
( %  dof: No. of dof per node) s
nl
ml
( %.........................................   ) s
nl
ml
( ) s
nl
ml
( % Initialization:) s
nl
ml
( %   K: Global stiffness matrix ) s
nl
ml
( %   p: Global load vector) s
nl
ml
( %   q: Global internal force vector ) s
nl
ml
( [K,p,q] = init\(rows\(X\),dof\);) s
nl
ml
( ) s
nl
ml
( % Assembly of element stiffness matrices.) s
nl
ml
( K = kq4e\(K,T,X,G\);) s
nl
ml
( ) s
nl
ml
( % Set nodal loads:) s
nl
ml
( p = setload\(p,P\); ) s
nl
ml
( ) s
nl
ml
( % Set boundary conditions. ) s
nl
ml
( [K,p] = setbc\(K,p,C,dof\);) s
nl
ml
( ) s
nl
ml
( % Solve equations:) s
nl
ml
( %  u: displacement vector) s
nl
ml
( u = K\\p;) s
nl
ml
( ) s
nl
ml
( % Postprocessing: ) s
nl
ml
( %  q: internal force vector) s
nl
ml
( %  S: stress matrix) s
nl
ml
( %  E: strain matrix) s
nl
ml
( [q,S,E] = qq4e\(q,T,X,G,u\);) s
nl
ml
( ) s
nl
ml
( ) s
nl
ml 
( ) s
nl
ml 
( ) s
nl
endpage 
startpage
ml
( % Open figure window No. 1) s
nl
ml
( figure\(1\)) s
nl
ml
( % Plot elements and nodes of topology T. ) s
nl
ml
( plotelem\(T,X\)) s
nl
ml
( hold on) s
nl
ml
( % Plot displaced configuration X+U \(scaled\)) s
nl
ml
( U = reshape\(u,cols\(X\),rows\(X\)\)';) s
nl
ml
( plotelem\(T,X+50*U,'c:'\)  ) s
nl
ml
( hold off) s
nl
ml
( ) s
nl
ml
( % Open figure window No. 2) s
nl
ml
( figure\(2\)) s
nl
ml
( % Contour plot of stress component No. 1: Sx) s
nl
ml
( plotq4\(T,X,S,1\)) s
nl
endpage

